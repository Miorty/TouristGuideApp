<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="34dp"
            android:paddingTop="160dp"
            android:paddingEnd="33dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Профиль"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:text="Чтобы полноценно использовать все\nфункции приложения, вам нужно войти в\nсистему"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/nameEditText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:text="guest@local"
                android:visibility="gone" />

            <EditText
                android:id="@+id/passwordEditText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:text="1234"
                android:visibility="gone" />

            <Button
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="35dp"
                android:background="@drawable/bg_white_card_outline"
                android:drawableStart="@drawable/ic_profile"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:drawablePadding="20dp"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="Авторизация"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/registerButton"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="27dp"
                android:background="@drawable/bg_route_card"
                android:drawableStart="@drawable/ic_phone"
                android:drawablePadding="22dp"
                android:gravity="center_vertical|start"
                android:paddingStart="18dp"
                android:text="Версия 1.0"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
