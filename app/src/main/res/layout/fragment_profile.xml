<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="33dp"
            android:paddingTop="31dp"
            android:paddingEnd="33dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="end"
                android:src="@drawable/ic_logout" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="118dp"
                android:layout_marginTop="42dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/profileInfoText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="6dp"
                    android:text="Иван Иванов\nНовичок"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_circle_outline"
                    android:padding="6dp"
                    android:src="@drawable/ic_profile" />
            </LinearLayout>

            <Button
                android:id="@+id/achievementsButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_white_card_outline"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="Достижения"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/favoritesButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_white_card_outline"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="Избранное"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/myRoutesButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_white_card_outline"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="Мои маршруты"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/tasksButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_white_card_outline"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="Еженедельное задание"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/settingsButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_white_card_outline"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="Настройки"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/addPlaceButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_white_card_outline"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="Добавить место"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/checkPlaceButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_white_card_outline"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="Проверить место"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_bottom_navigation" />
</LinearLayout>
