<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.35"
        android:orientation="vertical"
        android:paddingStart="34dp"
        android:paddingTop="160dp"
        android:paddingEnd="33dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Профиль"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="Чтобы полноценно использовать все\nфункции приложения, вам нужно войти в\nсистему"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/openLoginButton"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="35dp"
            android:background="@drawable/bg_white_card_outline"
            android:drawableStart="@drawable/ic_profile"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:drawablePadding="20dp"
            android:gravity="center_vertical|start"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:text="Авторизация"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="27dp"
            android:background="@drawable/bg_route_card"
            android:drawableStart="@drawable/ic_phone"
            android:drawablePadding="22dp"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="Версия 1.0"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        android:paddingStart="33dp"
        android:paddingTop="22dp"
        android:paddingEnd="33dp"
        android:paddingBottom="16dp">

        <View
            android:layout_width="49dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_handle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="37dp"
            android:text="Авторизация"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="37dp"
            android:text="Выберите удобный способ для входа в\nприложение"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/guestLoginButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Войти через VK ID"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="21dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Войти с Яндекс ID"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="25dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Войти с Google"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Авторизуясь, вы даёте согласие на обработку\nперсональных данных и условия использования"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>
</FrameLayout>
