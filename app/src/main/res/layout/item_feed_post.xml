<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="15dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Иван Иванов"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more_vertical" />
    </LinearLayout>

    <ImageView
        android:id="@+id/feedImage"
        android:layout_width="match_parent"
        android:layout_height="249dp"
        android:background="@drawable/bg_place_card"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:src="@drawable/feed_stone" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Необычная история появления!"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="31dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_favorite" />

        <TextView
            android:id="@+id/likesText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="40"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 мая 2026 г."
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="20dp"
            android:src="@drawable/ic_eye" />

        <TextView
            android:id="@+id/viewsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:text="2091"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/relatedPlaceContainer"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/relatedPlaceImage"
            android:layout_width="108dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_place_card"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:src="@drawable/place_bear" />

        <TextView
            android:id="@+id/relatedPlaceTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_weight="1"
            android:text="«Легенда о Пермском медведе»"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_right" />
    </LinearLayout>

    <View
        android:id="@+id/feedDivider"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:background="@color/surface_soft" />
</LinearLayout>
